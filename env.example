# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USER_IDS=123456789
TELEGRAM_POLL_INTERVAL_SECONDS=2

# App paths
PROJECTS_CONFIG_PATH=./projects.yaml
SQLITE_PATH=./data/app.db
MIGRATIONS_DIR=./migrations
DATA_DIR=./data
LOG_DIR=./data/logs
ARTIFACTS_DIR=./data/artifacts
SUMMARIES_DIR=./data/summaries

# Codex
CODEX_BIN=codex
CODEX_DEFAULT_SANDBOX_MODE=workspace-write
CODEX_DEFAULT_APPROVAL_MODE=on-request
CODEX_JSON_OUTPUT=true
CODEX_COMMAND_TIMEOUT_SECONDS=1800

# App behavior
LOG_LEVEL=INFO
DEFAULT_REPLY_LANGUAGE=zh-CN
DEFAULT_RISK_MODE=conservative
MAX_TELEGRAM_MESSAGE_LENGTH=3500
ENABLE_TYPING_INDICATOR=true
ENABLE_PROGRESS_UPDATES=true
ENABLE_DOCUMENT_UPLOAD=true
MAX_UPLOAD_SIZE_BYTES=209715200
UPLOAD_TEMP_DIR_NAME=.codex_telegram_uploads
ALLOWED_UPLOAD_EXTENSIONS=txt,md,markdown,json,yaml,yml,xml,csv,log,ini,toml,py,js,ts,tsx,jsx,go,rs,java,kt,swift,sql,html,css,apk

# Optional
DEFAULT_PROJECT=
